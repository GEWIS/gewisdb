{
    "name": "gewis/gewisdb",
    "description": "GEWIS Database management",
    "license": "GPL-3.0",
    "type": "project",
    "keywords": [
        "members",
        "decisions",
        "gewis"
    ],
    "homepage": "http://gewis.nl/",
    "require": {
        "php": "^8.4.0",
        "ext-intl": "*",
        "laminas/laminas-authentication": "^2.16.0",
        "laminas/laminas-config": "^3.9.0",
        "laminas/laminas-cli": "^1.10.0",
        "laminas/laminas-crypt": "^4.1.0",
        "laminas/laminas-eventmanager": "^3.13.0",
        "laminas/laminas-filter": "^2.34.0",
        "laminas/laminas-form": "^3.19.2",
        "laminas/laminas-http": "^2.19.0",
        "laminas/laminas-hydrator": "^4.15.0",
        "laminas/laminas-i18n": "^2.26.0",
        "laminas/laminas-i18n-resources": "^2.10.0",
        "laminas/laminas-inputfilter": "^2.30.0",
        "laminas/laminas-json": "^3.6.0",
        "laminas/laminas-ldap": "^2.18.1",
        "plesk/laminas-mail": "2.26.0-patch4",
        "plesk/laminas-mime": "2.13.0-patch2",
        "laminas/laminas-modulemanager": "^2.19.0",
        "laminas/laminas-mvc": "^3.7.0",
        "laminas/laminas-mvc-plugin-flashmessenger": "^1.10.1",
        "laminas/laminas-mvc-plugin-identity": "^1.6.0",
        "laminas/laminas-mvc-i18n": "^1.8.0",
        "laminas/laminas-progressbar": "^2.13.0",
        "laminas/laminas-router": "^3.13.0",
        "laminas/laminas-session": "^2.20.0",
        "laminas/laminas-serializer": "^2.17.0",
        "laminas/laminas-servicemanager": "^3.22.1",
        "laminas/laminas-stdlib": "^3.19.0",
        "laminas/laminas-validator": "^2.52.0",
        "laminas/laminas-view": "^2.34.0",
        "doctrine/dbal": "*",
        "doctrine/orm": "*",
        "doctrine/common": "*",
        "doctrine/doctrine-laminas-hydrator": "^3.4.0",
        "monolog/monolog": "^3.10.0",
        "cweagans/composer-patches": "^2.0.0",
        "stripe/stripe-php": "^20.0",
        "doctrine/data-fixtures": "^2.0",
        "doctrine/migrations": "^3.9",
        "doctrine/doctrine-orm-module": "^6.3.0",
        "phlak/semver": "^6.1"
    },
    "require-dev": {
        "laminas/laminas-component-installer": "^3.4.0",
        "laminas/laminas-developer-tools": "^2.9.0",
        "laminas/laminas-loader": "^2.10.0",
        "laminas/laminas-test": "^4.10.0",
        "san/san-session-toolbar": "^5.1.0",
        "phpunit/phpunit": "^12.0.0",
        "squizlabs/php_codesniffer": "^3.9.0",
        "friendsofphp/php-cs-fixer": "^3.52.1",
        "phpstan/phpstan": "^2.0.0",
        "phpstan/extension-installer": "^1.3.1",
        "bnf/phpstan-psr-container": "^1.1.0",
        "slam/phpstan-laminas-framework": "^2.1.1",
        "phpstan/phpstan-doctrine": "^2.0.0",
        "phpstan/phpstan-phpunit": "^2.0.0",
        "vimeo/psalm": "^6.8.4",
        "lctrs/psalm-psr-container-plugin": "^1.11.0",
        "weirdan/doctrine-psalm-plugin": "^2.10.0",
        "psalm/plugin-phpunit": "^0.19.5",
        "maglnet/composer-require-checker": "^4.16.1",
        "icanhazstring/composer-unused": "^0.9.6",
        "gewis/gewisphp-coding-standards": "^1.3.1"
    },
    "config": {
        "preferred-install": {
            "doctrine/orm": "source",
            "*": "dist"
        },
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "laminas/laminas-dependency-plugin": true,
            "cweagans/composer-patches": true,
            "laminas/laminas-component-installer": true,
            "phpstan/extension-installer": true,
            "icanhazstring/composer-unused": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "discard-changes" : true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "patches": {
            "doctrine/orm": {
                "Fix issues with SubDecisions.": "https://raw.githubusercontent.com/GEWIS/orm/2.20.x/1-to-1-multiple-join-columns.patch"
            }
        }
    },
    "repositories": [
        {
            "type": "git",
            "url": "https://github.com/GEWIS/gewisphp-coding-standards.git"
        },
        {
            "type": "git",
            "url": "https://github.com/GEWIS/laminas-crypt.git"
        }
    ],
    "autoload": {
        "psr-4": {
            "Application\\": "module/Application/src",
            "Checker\\": "module/Checker/src",
            "Database\\": "module/Database/src",
            "Report\\": "module/Report/src",
            "User\\": "module/User/src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ApplicationTest\\": "module/Application/test",
            "CheckerTest\\": "module/Checker/test"
        }
    }
}
